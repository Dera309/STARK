# API Configuration
VITE_API_URL=http://localhost:3003/api/v1
VITE_SOCKET_URL=http://localhost:3003

# Firebase Authentication Configuration
# Get these values from: https://console.firebase.google.com/ -> Project Settings -> General -> Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Tawk.to Live Chat Configuration
# Get your Property ID and Widget ID from: https://tawk.to/dashboard
# Go to Administration > Channels > Chat Widget
# The propertyId and widgetId will be found in the Direct Chat Link section
