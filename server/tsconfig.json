{
  "extends": "../tsconfig.base.json",
   "compilerOptions": {
     "module": "Node16",
     "moduleResolution": "node16",
     "outDir": "./dist",
     "lib": ["ES2020"],
     "skipLibCheck": true,
     "noImplicitAny": false,
     "strict": false,
     "composite": false,
     "baseUrl": "../",
     "paths": {
       "@shared/*": ["shared/src/*"]
     }
   },
   "include": ["src/**/*", "../shared/src"],
   "exclude": ["src/tests/**/*", "src/scripts/**/*"]
}
