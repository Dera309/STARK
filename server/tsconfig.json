{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false,
    "composite": false,
    "baseUrl": "../",
    "paths": {
      "@shared/*": ["shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/tests/**/*", "src/scripts/**/*"]
}
