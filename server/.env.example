# Server
PORT=3003
NODE_ENV=development

# Database
# For local development: MONGODB_URI=mongodb://localhost:27017/stark
# For production/Atlas: MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/stark
MONGODB_URI=mongodb://localhost:27017/stark

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# Firebase Admin Configuration
# Download service account key JSON from Firebase Console and save it locally
# Set the path to the JSON file here
FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@example.com
EMAIL_PASS=your-email-password

# Client URL for CORS
CLIENT_URL=http://localhost:5173
